# Enterprise SecureChat — Environment Variables
# Copy this file to .env and fill in real values before running docker compose.
# Never commit .env to git.

# ── Neon PostgreSQL ───────────────────────────────────────────────────────────
# App database (FGA registry, conversations, messages)
# psql/tools format — used for Neon CLI, psql, DB GUIs
# Format: postgresql://user:password@ep-yyyx.region.aws.neon.tech/fga_registry?sslmode=require
NEON_APP_URL=postgresql://user:password@ep-yyyx.region.aws.neon.tech/fga_registry?sslmode=require

# JDBC format — required by Spring Boot / HikariCP (note the jdbc: prefix)
# Format: jdbc:postgresql://ep-yyyx.region.aws.neon.tech/fga_registry?sslmode=require&user=yyy&password=yyy
SPRING_DATASOURCE_URL=jdbc:postgresql://ep-yyyx.region.aws.neon.tech/fga_registry?sslmode=require&user=yyy&password=yyy

# Keycloak backing database (Keycloak manages its own schema here)
# Use a SEPARATE Neon database from the app DB
# Format: jdbc:postgresql://ep-yyyx.region.aws.neon.tech/keycloak?sslmode=require&user=yyy&password=yyy
NEON_KEYCLOAK_URL=jdbc:postgresql://ep-yyyx.region.aws.neon.tech/keycloak?sslmode=require&user=yyy&password=yyy

# ── Keycloak ──────────────────────────────────────────────────────────────────
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=changeme

# ── Qdrant ────────────────────────────────────────────────────────────────────
# API key for the local Qdrant instance
QDRANT_API_KEY=changeme

# ── Anthropic / Claude ────────────────────────────────────────────────────────
# Get your key at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── Application ───────────────────────────────────────────────────────────────
# JWT signing secret used internally (not Keycloak — this is for internal tokens if needed)
APP_JWT_SECRET=changeme-use-a-long-random-string
