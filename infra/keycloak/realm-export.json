{
  "realm": "enterprise-securechat",
  "displayName": "Enterprise SecureChat",
  "enabled": true,
  "sslRequired": "external",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "editUsernameAllowed": false,
  "bruteForceProtected": true,
  "accessTokenLifespan": 1800,
  "ssoSessionIdleTimeout": 3600,
  "ssoSessionMaxLifespan": 36000,

  "roles": {
    "realm": [
      { "name": "admin",                 "description": "Full system access including admin panel" },
      { "name": "reserves-coordination", "description": "Reserves coordination — access to BAR questions and cross-BU corporate answers" },
      { "name": "reserves-management",   "description": "Reserves management — access to BAR questions, volumes, and financial figures unredacted" },
      { "name": "reservoir-team",        "description": "Reservoir engineering team — no access to BAR questions or ANP restricted content" },
      { "name": "bu-user",               "description": "Business Unit user — access restricted to own BU content and corporate answers" }
    ]
  },

  "groups": [
    { "name": "BU_Campos",   "path": "/BU_Campos"   },
    { "name": "BU_Santos",   "path": "/BU_Santos"   },
    { "name": "BU_Solimoes", "path": "/BU_Solimoes" }
  ],

  "clients": [
    {
      "clientId": "securechat-frontend",
      "name": "SecureChat Angular Frontend",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "redirectUris": [
        "http://localhost:4200/*",
        "http://localhost:80/*"
      ],
      "webOrigins": [
        "http://localhost:4200",
        "http://localhost:80"
      ],
      "protocol": "openid-connect",
      "fullScopeAllowed": true,
      "defaultClientScopes": ["openid", "profile", "email", "roles", "groups"]
    },
    {
      "clientId": "securechat-backend",
      "name": "SecureChat Spring Boot Backend",
      "enabled": true,
      "publicClient": false,
      "serviceAccountsEnabled": true,
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "secret": "CHANGE_THIS_SECRET",
      "protocol": "openid-connect",
      "defaultClientScopes": ["openid", "profile", "email", "roles", "groups"]
    }
  ],

  "clientScopes": [
    {
      "name": "roles",
      "protocol": "openid-connect",
      "attributes": { "include.in.token.scope": "true" },
      "protocolMappers": [
        {
          "name": "realm roles",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "consentRequired": false,
          "config": {
            "multivalued": "true",
            "userinfo.token.claim": "true",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "realm_access.roles",
            "jsonType.label": "String"
          }
        }
      ]
    },
    {
      "name": "groups",
      "protocol": "openid-connect",
      "attributes": { "include.in.token.scope": "true" },
      "protocolMappers": [
        {
          "name": "groups",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-group-membership-mapper",
          "consentRequired": false,
          "config": {
            "full.path": "false",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "groups",
            "userinfo.token.claim": "true",
            "multivalued": "true"
          }
        }
      ]
    }
  ],

  "defaultDefaultClientScopes": ["openid", "profile", "email", "roles", "groups"],

  "browserSecurityHeaders": {
    "contentSecurityPolicy": "frame-src 'self'; frame-ancestors 'self'; object-src 'none';",
    "xContentTypeOptions": "nosniff",
    "xRobotsTag": "none",
    "xFrameOptions": "SAMEORIGIN",
    "strictTransportSecurity": "max-age=31536000; includeSubDomains"
  }
}
