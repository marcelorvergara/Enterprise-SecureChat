# Enterprise SecureChat — Environment Variables
# Copy this file to .env and fill in real values before running docker compose.
# Never commit .env to git.

# ── Neon PostgreSQL ───────────────────────────────────────────────────────────
# App database (FGA registry, conversations, messages)
# psql/tools format — used for Neon CLI, psql, DB GUIs
NEON_APP_URL=postgresql://<user>:<password>@<endpoint>.neon.tech/fga_registry?sslmode=require

# JDBC format — required by Spring Boot / HikariCP (note the jdbc: prefix)
SPRING_DATASOURCE_URL=jdbc:postgresql://<endpoint>.neon.tech/fga_registry?sslmode=require
SPRING_DATASOURCE_USERNAME=<neon-username>
SPRING_DATASOURCE_PASSWORD=<neon-password>

# Keycloak backing database — must be a SEPARATE Neon database from the app DB
NEON_KEYCLOAK_URL=jdbc:postgresql://<endpoint>.neon.tech/keycloak?user=<neon-username>&password=<neon-password>&sslmode=require

# ── Keycloak ──────────────────────────────────────────────────────────────────
KEYCLOAK_ADMIN=<admin-username>
KEYCLOAK_ADMIN_PASSWORD=<strong-random-password>

# ── Qdrant ────────────────────────────────────────────────────────────────────
# API key — generate a strong random string (e.g. openssl rand -hex 32)
QDRANT_API_KEY=<strong-random-api-key>
# Qdrant URL: Qdrant Cloud URL or http://qdrant:6333 for local Docker
QDRANT_URL=https://<cluster-id>.<region>.aws.cloud.qdrant.io

# ── Anthropic / Claude ────────────────────────────────────────────────────────
# Get your key at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── Application ───────────────────────────────────────────────────────────────
# JWT signing secret — generate with: openssl rand -hex 64
APP_JWT_SECRET=<long-random-hex-string>
